# Обязательно для всех трёх stage — LiveKit Inference (STT/LLM/TTS) идёт
# через эти креды, отдельные ключи провайдеров не нужны.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Только для stages/stage3_ru_openrouter.py — LLM с открытыми весами через
# OpenRouter (путь на on-prem). Ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# Опционально — Langfuse-трассировка (tracing.py). Без этих двух ключей
# трейсинг просто отключён (no-op), агент работает как обычно.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
